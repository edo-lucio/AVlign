#!/bin/bash
#SBATCH --job-name=vggsound_download
#SBATCH --output=logs/download%j.out
#SBATCH --error=logs/download%j.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=12:00:00
#SBATCH --partition=acltr
#SBATCH --gres=gpu:1
#SBATCH --mail-user=edlu@itu.dk
#SBATCH --mail-type=FAIL

python ./data/vggsound_download.py