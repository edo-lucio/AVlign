#!/bin/bash
#SBATCH --job-name=fgw_eval
#SBATCH --output=logs/fgw_eval_%j.out
#SBATCH --error=logs/fgw_eval_%j.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=2:00:00
#SBATCH --partition=scavenge
#SBATCH --mail-user=edlu@itu.dk
#SBATCH --mail-type=FAIL

set -e
set -x

# --- 1. Environment & Path Definitions ---
PROJECT_DIR="$HOME/flowting-fgw-v2a"
ENV_PATH="/home/edlu/miniconda3-25-5-1-1/envs/gwot"
CONDA_BIN="/opt/itu/easybuild/software/Miniconda3/25.5.1-1/bin/conda"

# --- 2. Load System Modules ---
module load CUDA/12.1.1
module load NCCL/2.18.3-GCCcore-12.3.0-CUDA-12.1.1
module load Miniconda3/25.5.1-1
source /opt/itu/easybuild/software/Miniconda3/25.5.1-1/etc/profile.d/conda.sh
conda activate "$ENV_PATH"
cd "$PROJECT_DIR"

export TORCH_DEVICE_BACKEND_AUTOLOAD=0

EMB_DIR="${EMB_DIR:-data/embeddings}"

# --- 3. Evaluate ----------------------------------------------------------
# RESULTS_GLOB matches every fgw_*.json the experiments sweep produced; the
# eval script filters out *_eval.json so re-runs don't re-process its own
# outputs.  Set SKIP_EVAL=1 to skip and only render plots.
#
# BOOTSTRAP_B controls within-seed CIs (default 1000); NULL_K controls the
# random-π structural null reference (default 200). Set to 0 to skip either.
RESULTS_GLOB="${RESULTS_GLOB:-fgw_validation/data/results/fgw_*.json}"
if [ "${SKIP_EVAL:-0}" != "1" ]; then
    python -m fgw_validation.eval \
        --emb "$EMB_DIR" \
        --bootstrap_B "${BOOTSTRAP_B:-1000}" \
        --null_K      "${NULL_K:-200}" \
        --results $RESULTS_GLOB
fi

# --- 4. Pairwise CKA on canonical (dataset, split, modality) targets ------
# These feed the CKA heatmaps and the perf-vs-CKA scatters. `|| true` so a
# missing modality (e.g. fewer than two encoders present) doesn't abort the
# job. Set SKIP_CKA=1 to skip.
if [ "${SKIP_CKA:-0}" != "1" ]; then
    CKA_N="${CKA_N:-1000}"
    for MOD in image text; do
        python -m fgw_validation.cka --dataset flickr8k --split test \
            --modality "$MOD" --kernel linear --n "$CKA_N" \
            --emb_root "$EMB_DIR" || true
    done
    python -m fgw_validation.cka --dataset flickr8k --split test \
        --modality text --kernel rbf --n "$CKA_N" \
        --emb_root "$EMB_DIR" || true
    for MOD in audio text; do
        python -m fgw_validation.cka --dataset clotho --split development \
            --modality "$MOD" --kernel linear --n "$CKA_N" \
            --emb_root "$EMB_DIR" || true
    done
fi

# --- 5. Pre-experiment dataset overlap diagnostic ------------------------
# Distribution of `max_j cos(cap_img_i, cap_aud_j)` per image — tells us
# how much semantic overlap even exists between Flickr8k and Clotho before
# any FGW. Run once per witness encoder. Skip with SKIP_OVERLAP=1.
FIG_DIR="${FIG_DIR:-fgw_validation/data/figures}"
if [ "${SKIP_OVERLAP:-0}" != "1" ]; then
    for W in clip t5 lex; do
        python -m fgw_validation.dataset_overlap --witness "$W" \
            --emb_root "$EMB_DIR" --out_dir "$FIG_DIR" || true
    done
fi

# --- 6. Render figures ----------------------------------------------------
# Sections: alpha curves, leaderboard heatmaps, transport diagnostics, CKA
# heatmaps, UMAPs (umap-learn optional), perf-vs-CKA scatters, geo ablation,
# diag (struct↔semantic permutation), primary-config spotlight.
if [ "${SKIP_PLOTS:-0}" != "1" ]; then
    python -m fgw_validation.plots \
        --emb_root "$EMB_DIR" \
        --out_dir  "$FIG_DIR"
fi
